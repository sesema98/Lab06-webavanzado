<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Social Media Lab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <main class="shell shell-home">
      <section class="hero-card">
        <p class="eyebrow">Laboratorio 06</p>
        <h1>Social Media con Node.js, MongoDB y CRUD web</h1>
        <p class="hero-copy">
          Aplicacion construida con Express, EJS y Mongoose para registrar,
          listar, editar y eliminar publicaciones.
        </p>

        <div class="hero-actions">
          <a class="btn btn-primary" href="/posts">Ver publicaciones</a>
          <a class="btn btn-secondary" href="/posts/new">Registrar nuevo post</a>
        </div>

        <div class="hero-grid">
          <article>
            <span>Base de datos</span>
            <strong>MongoDB</strong>
          </article>
          <article>
            <span>Motor web</span>
            <strong>Express + EJS</strong>
          </article>
          <article>
            <span>Modelo ODM</span>
            <strong>Mongoose</strong>
          </article>
        </div>
      </section>
    </main>
  </body>
</html>
