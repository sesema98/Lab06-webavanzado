<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Newsreader:opsz,wght@6..72,500;6..72,600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="app-body">
    <main class="container">
      <section class="page-header form-header">
        <div>
          <span class="section-label">Formulario</span>
          <h1><%= pageTitle %></h1>
          <p class="intro-text compact-text">
            Completa los datos del post y guarda los cambios.
          </p>
        </div>

        <div class="header-actions">
          <a class="btn btn-secondary" href="/posts">Volver al listado</a>
        </div>
      </section>

      <section class="form-card">
          <% if (errors.length) { %>
            <div class="alert alert-error">
              <% errors.forEach((error) => { %>
                <p><%= error %></p>
              <% }) %>
            </div>
          <% } %>

          <form class="post-form" action="<%= formAction %>" method="POST">
            <div class="form-grid">
              <label>
                Autor
                <select name="userId" required>
                  <option value="">Selecciona un usuario</option>
                  <% users.forEach((user) => { %>
                    <option
                      value="<%= user._id %>"
                      <%= formData.userId === String(user._id) ? "selected" : "" %>
                    >
                      <%= `${user.name} ${user.lastName}` %>
                    </option>
                  <% }) %>
                </select>
              </label>

              <label>
                Titulo
                <input
                  type="text"
                  name="title"
                  minlength="5"
                  maxlength="30"
                  required
                  value="<%= formData.title %>"
                />
              </label>
            </div>

            <label>
              Contenido
              <textarea name="content" rows="8" minlength="10" required><%= formData.content %></textarea>
            </label>

            <div class="form-grid">
              <label>
                Hashtags
                <input
                  type="text"
                  name="hashtags"
                  placeholder="#mongodb, #nodejs, #crud"
                  value="<%= formData.hashtags %>"
                />
              </label>

              <label>
                URL de imagen
                <input
                  type="url"
                  name="imageUrl"
                  placeholder="https://ejemplo.com/imagen.jpg"
                  value="<%= formData.imageUrl %>"
                />
              </label>
            </div>

            <div class="button-row">
              <button class="btn btn-primary" type="submit"><%= submitLabel %></button>
              <a class="btn btn-secondary" href="/posts">Cancelar</a>
            </div>
          </form>
      </section>
    </main>
  </body>
</html>
