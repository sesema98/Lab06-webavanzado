<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Listado de Posts</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Newsreader:opsz,wght@6..72,500;6..72,600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="app-body">
    <main class="container">
      <section class="page-header">
        <div>
          <span class="section-label">CRUD de Posts</span>
          <h1>Publicaciones registradas</h1>
          <p class="intro-text compact-text">
            Lista de posts almacenados en MongoDB.
          </p>
        </div>

        <div class="header-actions">
          <div class="status-box">
            <span>Total</span>
            <strong><%= posts.length %></strong>
          </div>

          <a class="btn btn-secondary" href="/">Inicio</a>
          <a class="btn btn-primary" href="/posts/new">Nuevo post</a>
        </div>
      </section>

      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>

      <% if (!posts.length) { %>
        <section class="empty-state">
          <h2>No hay publicaciones todavia</h2>
          <p>Usa el formulario para crear tu primer post.</p>
        </section>
      <% } %>

      <section class="posts-grid">
        <% posts.forEach((post) => { %>
          <article class="post-card">
            <% if (post.imageUrl) { %>
              <img class="post-image" src="<%= post.imageUrl %>" alt="Imagen del post" />
            <% } else { %>
              <div class="post-image post-image-placeholder">
                <span>Sin imagen</span>
              </div>
            <% } %>

            <div class="post-body">
              <div class="post-meta">
                <span><%= new Date(post.createdAt).toLocaleString("es-PE") %></span>
                <% if (post.updatedAt) { %>
                  <span class="meta-badge">Actualizado</span>
                <% } %>
              </div>

              <h2><%= post.title %></h2>
              <p><%= post.content %></p>

              <div class="hashtags">
                <% post.hashtags.forEach((tag) => { %>
                  <span class="chip"><%= tag %></span>
                <% }) %>
              </div>
            </div>

            <div class="post-footer">
              <div class="author-box">
                <small>Autor</small>
                <strong><%= post.user ? `${post.user.name} ${post.user.lastName}` : "Sin autor" %></strong>
              </div>

              <div class="button-row">
                <a class="btn btn-small btn-secondary" href="/posts/<%= post._id %>/edit">Editar</a>
                <form action="/posts/<%= post._id %>/delete" method="POST">
                  <button class="btn btn-small btn-danger" type="submit">Eliminar</button>
                </form>
              </div>
            </div>
          </article>
        <% }) %>
      </section>
    </main>
  </body>
</html>
